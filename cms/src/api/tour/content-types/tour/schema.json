{
  "kind": "collectionType",
  "collectionName": "tours",
  "info": {
    "singularName": "tour",
    "pluralName": "tours",
    "displayName": "Tour",
    "description": "Safari tour itineraries"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "integer",
      "required": true
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "maxGuests": {
      "type": "integer",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "highlights": {
      "type": "json",
      "required": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "itinerary": {
      "type": "component",
      "repeatable": true,
      "component": "tour.itinerary-day"
    }
  }
}
